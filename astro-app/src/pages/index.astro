  <nav class="page-subnav" id="page-subnav" role="navigation" aria-label="Page sections">
    <ul class="nav nav-pills page-subnav__top" id="section-tabs" role="tablist">
      {sections.map(s => (
        <li class="nav-item" role="presentation">
          <button class="nav-link tab subdomain-tab" data-section={s.id} role="tab">
            {s.label}
          </button>
        </li>
      ))}
    </ul>
    <ul class="nav nav-pills page-subnav__sub" id="subsection-tabs" role="tablist"></ul>
  </nav>


  <!-- Our Project Section -->
  <section class="our-project-hero" id="our-project">
    <div class="project-hero-content">
      <h2>Our Project</h2>
      <p>The future of secure research depends on skilled, knowledgeable, and experienced colleagues who can navigate complex technical and governance landscapes. In addition to defining core competencies at entry, mid, and senior levels for existing colleagues to help them to navigate and plan their career progression, we're developing the next generation of secure data environment professionals through hands-on projects, structured mentoring, and bespoke training and development plans. Discover how we're using insights from our competency framework to guide our students and trainees, and how their real-world experiences are feeding back into the framework to ensure it remains grounded in practice.</p>
    </div>
  </section>

  <!-- Student Projects Section -->
  <section class="student-projects-section" id="student-projects">
    <h2>Student Projects</h2>
    <p class="section-intro">
      To ensure future sustainability for the technical workforce, we are supervising students from Masters degree programmes at the three host institutions. 
      Over two academic years, we have proposed research and technical projects with real-world usecases from Secure Data Environments in the North West of England. 
      In addition, all of our research team provide mentoring to students to help them to develop technical/professional skills and to discover formal training opportunities that will help them to standout in the jobs market post-graduation, 
      and to inspire them to pursue careers designing, developing, and operating SDEs. Find out more about our students below:
    </p>
    <div class="projects-grid row g-4">
      {featuredStudents.map(s => (
        <div class="col-12 col-md-6 col-lg-4">
          <div class="project-card glass--soft">
            <div class="card-header">
              <div class="card-info">
                <h3>{s.name}</h3>
                <p class="student-institution">{s.institution}</p>
                <p class="student-course">{s.course}</p>
                {s.status && <p class="">{s.status}</p>}
              </div>
              <div class="card-photo">
                <img src={s.photo} alt={s.name} />
              </div>
            </div>
            <div class="project-content">
              <h4 class="project-title">{s.projectTitle}</h4>
              <p class="project-description">{s.projectDescription}</p>
              <a href={`/placement-case-studies/#${s.caseStudyAnchor}`} class="read-more">Read full story →</a>
            </div>
          </div>
        </div>
      ))}
    </div>
    <div class="projects-link-container">
      <a href="/placement-case-studies/" class="projects-link">Find out about all our student projects here</a>
    </div>
  </section>

  <!-- RTP Placements Section -->
  <section class="rtp-section" id="rtp-placements">
    <h2>RTP Professional Placements</h2>
    <p class="section-intro">
    This programme has funded 3 full-time trainee positions for early careers Research Technical Professionals with aspirations to design, build, and operate secure research infrastructure.
    Find out more about our trainees below:
    </p>
    <div class="rtp-grid row g-4">
      {rtps.map(r => (
        <div class="col-12 col-md-6 col-lg-4">
          <div class="rtp-card glass--soft">
            <div class="card-header">
              <div class="card-info">
                <h3>{r.name}</h3>
                <p class="team-affiliation">{r.affiliation}</p>
                <p class="team-role">{r.role}</p>
              </div>
              <div class="rtp-photo">
                <img src={r.photo} alt={r.name} />
              </div>
            </div>
            <div class="rtp-content">
              <p class="rtp-focus"><strong>Focus:</strong> {r.focus}</p>
              <p class="rtp-quote">{r.quote}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
    <div class="rtp-link-container">
      <a href="/professional-training-placements/" class="rtp-placement-link">Find out more about our RTP placements here</a>
    </div>
  </section>

  <!-- Team Section -->
  <section class="team-section" id="team">
    <h2>Us</h2>
    <p class="section-intro">Meet the multidisciplinary team behind the SDE Team Development Hub.</p>

    <!-- Team Leads -->
    <h3 class="team-members-heading" id="site-leads">Site Leads</h3>
    <div class="team-leads row g-4">
      {siteLeads.map(l => (
        <div class="col-12 col-md-6 col-lg-4">
          <div class="lead-card glass--soft">
            <div class="card-header">
              <div class="card-info">
                <h3>{l.name}</h3>
                <p class="team-affiliation">{l.affiliation}</p>
              </div>
