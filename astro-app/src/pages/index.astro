  <div class="scroll-area">
  <div class="home-hero row g-4 align-items-center" id="home-hero">
    <div class="hero-content col-12 col-lg-6">
      <h1 class="hero-title">SDE Team Development Hub</h1>
      <p class="hero-subtitle">Developing technical capability and capacity for UK Secure Data Environments</p>
      <div class="hero-cta-group d-flex flex-wrap gap-3">
        <a href="#explore" class="hero-cta">View our project</a>
        <a href="#explore" class="hero-cta">Explore the Framework</a>
