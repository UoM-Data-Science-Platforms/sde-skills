---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';

const sections = [
  { id: 'eoi', label: 'EOI' },
];
---

<Layout title="Expression of Interest - EOI" currentDomain="expression-of-interest">
  <div class="skills-framework">
    <PageHeader title="Expression of Interest" />
    <div class="sticky-subnav">
      <div class="subdomain-tabs" id="section-tabs">
        {sections.map(s => (
          <button class="tab subdomain-tab" data-section={s.id}>
            {s.label}
          </button>
        ))}
      </div>
    </div>
    <div class="scroll-area" id="scroll-area">
      <div class="page-container">
        <h2 id="eoi">Expression of Interest now open</h2>

        <article class="card eoi-card">
          <h3>Residential Workshop: Supporting the next generation of technical professionals</h3>
          <p>A hands-on residential technical training and skills development workshop demonstrating and consolidating the outputs of the programme.</p>

          <p><strong>Date:</strong> November 11th – 13th, 2026</p>
          <p><strong>Location:</strong> The Rookery, Nantwich</p>
          <p><strong>Aimed at:</strong> Early Career Research Technical Professionals</p>
          <p><strong>Fully funded:</strong> workshop, accommodation, and full board included</p>
          <p><strong>Delegates must pay for their own transport</strong></p>

          <p>To receive further information and to be notified of when the application process is open, please complete this short  <a class="link" href="https://docs.google.com/forms/d/1RTA5fDU3FWgeSXA9qEx14p5XD9pPJhxNRGaOjF1b1k8/edit">expression of interest form</a></p>

          <p>For more info contact <a class="link" href="mailto:ruth.norris@manchester.ac.uk">ruth.norris@manchester.ac.uk</a></p>
        </article>
      </div>
    </div>
  </div>
</Layout>

<script define:vars={{ sections }}>
  window._pageSections = sections;
</script>
<script>
  import { initScrollSync } from '../scripts/scrollSync.js';
  initScrollSync({ sections: window._pageSections });
</script>
