---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import { placementStudents } from '../data/students.js';

const sections = [
  { id: 'summary', label: 'Summary' },
  { id: 'case-studies', label: 'Student experiences' },
];

const studentsWithBios = placementStudents.filter(s => s.bio.length > 0 || s.summary.length > 0);
---

<Layout title="Student Projects - Placement Case Studies" currentDomain="placement-case-studies">
  <div class="skills-framework">
    <PageHeader title="Student Projects" />
    <div class="sticky-subnav">
      <div class="subdomain-tabs" id="section-tabs">
        {sections.map(s => (
          <button class="tab subdomain-tab" data-section={s.id}>
            {s.label}
          </button>
        ))}
      </div>
    </div>
    <div class="scroll-area" id="scroll-area">
      <section class="mini-hero">
        <div class="mini-hero-content">
          <h2 id="summary">Student Projects Summary</h2>
          <p>Our cohort of students are undertaking short projects supported by the project. See the table below for a summary, followed by a selection of reflective student case studies.</p>
        </div>
      </section>
      <div class="container-fluid px-4 py-4">
        <div class="table-responsive">
          <table class="table table-hover">
            <thead class="table-light">
              <tr>
                <th>Site</th>
                <th>Scheme</th>
                <th>Project title</th>
                <th>Dates</th>
                <th>Student name</th>
              </tr>
            </thead>
            <tbody>
              {placementStudents.map(s => (
                <tr class={s.bio.length > 0 || s.summary.length > 0 ? 'table-row-clickable' : ''} data-student={s.id}>
                  <td>{s.site}</td>
                  <td>{s.scheme}</td>
                  <td>{s.projectTitle}</td>
                  <td>{s.dates}</td>
                  <td>{s.name}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <h2 id="case-studies">Student experiences</h2>

        <div class="cards-grid">
          {studentsWithBios.map(s => (
            <article class="card glass--soft" id={`student-${s.id}`}>
              <div class="card-header">
                <div class="card-info">
                  <h2 class={`card-title${s.titleStyle ? ` ${s.titleStyle}` : ''}`}>{s.name}</h2>
                  <div class="info-row"><i>{s.projectTitle}</i></div>
                  {s.course && <div class="info-row"><strong>Course:</strong> {s.course}</div>}
                  {s.institution && <div class="info-row"><strong>Institution:</strong> {s.institution}</div>}
                </div>
                {s.photo && (
                  <div class="card-photo">
                    <img src={s.photo} alt={s.name} />
                  </div>
                )}
              </div>
              <div class="card-body">
                {s.bio.length > 0 && (
                  <>
                    <p class="card-text"><strong>Biography:</strong> {s.bio[0]}</p>
                    {s.bio.slice(1).map(p => <p class="card-text">{p}</p>)}
                  </>
                )}
                {s.summary.length > 0 && (
                  <>
                    <p class="card-text"><strong>Project Summary:</strong> {s.summary[0]}</p>
                    {s.summary.slice(1).map(p => <p class="card-text">{p}</p>)}
                  </>
                )}
                {s.supervision && s.supervision.length > 0 && (
                  <>
                    <p class="card-text"><strong>Supervision:</strong> {s.supervision[0]}</p>
                    {s.supervision.slice(1).map(p => <p class="card-text">{p}</p>)}
                  </>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </div>
</Layout>

<script define:vars={{ sections }}>
  window._pageSections = sections;
</script>
<script>
  import { initScrollSync } from '../scripts/scrollSync.js';
  initScrollSync({ sections: window._pageSections });

  // Make table rows clickable to scroll to case study cards
  document.querySelectorAll('.table-row-clickable').forEach(row => {
    row.addEventListener('click', () => {
      const studentId = row.dataset.student;
      const card = document.getElementById(`student-${studentId}`);
      if (card) {
        const scrollArea = document.querySelector('.scroll-area');
        if (scrollArea) {
          card.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }
    });
  });
</script>
