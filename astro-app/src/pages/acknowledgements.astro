---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
---

<Layout title="Acknowledgements & Attributions – SDE Skills Hub" currentDomain="acknowledgements">
  <div class="skills-framework">
    <PageHeader title="Acknowledgements & Attributions" />
    <div class="scroll-area">
      <div class="container-fluid px-4 py-4">
        <section class="ack-section">
          <h2>Funding</h2>
          <div class="glass ack-card ack-card--funding">
            <img
              src="/assets/images/eprsc_logo.png"
              alt="EPSRC Logo"
              class="ack-logo"
            />
            <p>
              This site has been developed as part of the research project <a href="https://gtr.ukri.org/projects?ref=EP%2FY530591%2F1">Developing technical capability and capacity for UK Secure Data Environments,</a> and has been funded by the Engineering and Physical Sciences Research Council (EPSRC) [grant number EP/Y530591/1].
            </p>
          </div>
        </section>

        <section class="ack-section">
          <h2>Host institutions</h2>
          <div class="ack-grid">
            <article class="glass ack-card">
              <h3>The University of Manchester</h3>
              <img
                src="/assets/images/manchester-logo.png"
                alt="The University of Manchester Logo"
                class="ack-logo"
              />
            </article>

            <article class="glass ack-card">
              <h3>University of Liverpool</h3>
              <img
                src="/assets/images/liverpool-logo.png"
                alt="University of Liverpool Logo"
                class="ack-logo"
              />
            </article>

            <article class="glass ack-card">
              <h3>Lancashire Teaching Hospitals NHS Foundation Trust</h3>
              <img
                src="/assets/images/lancashire-nhs-logo.jpg"
                alt="Lancashire Teaching Hospitals NHS Foundation Trust Logo"
                class="ack-logo"
              />
            </article>
          </div>
        </section>

        <section class="ack-section">
          <h2>Industry Partners</h2>
          <div class="ack-grid">
            <article class="glass ack-card">
              <h3>ARO Technology</h3>
              <img
                src="/assets/images/aro-logo.jpeg"
                alt="ARO Technology logo"
                class="ack-logo"
              />
              <p>
                <strong>Website:</strong> <a href="https://aro.tech/">https://aro.tech/</a>
              </p>
            </article>

            <article class="glass ack-card">
              <h3>Mersey Care NHS Trust</h3>
              <img
                src="/assets/images/mersey-care-logo.png"
                alt="Mersey Care NHS Trust Logo"
                class="ack-logo"
              />
              <p>
                <strong>Website:</strong> <a href="https://www.merseycare.nhs.uk/">https://www.merseycare.nhs.uk/</a>
              </p>
            </article>

            <article class="glass ack-card">
              <h3>Health Innovation Manchester</h3>
              <img
                src="/assets/images/hinm_logo.png"
                alt="Health Innovation Manchester logo"
                class="ack-logo ack-logo--hinm"
              />
              <p>
                <strong>Website:</strong> <a href="https://healthinnovationmanchester.com/">https://healthinnovationmanchester.com/</a>
              </p>
            </article>
          </div>
        </section>
      </div>
    </div>
  </div>
</Layout>
