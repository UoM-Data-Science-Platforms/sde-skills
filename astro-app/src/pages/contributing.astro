---
import { Content } from '../../data/contributing.md';
import Layout from '../layouts/Layout.astro';

const sections = [
  { id: 'ways-to-contribute',                                        label: 'Ways to Contribute'  },
  { id: 'option-1-creating-an-issue-non-technical-approach',         label: 'Option 1: Issues'    },
  { id: 'option-2-submitting-changes-via-pull-request',              label: 'Option 2: Pull Requests' },
  { id: 'guidelines-for-contributions',                              label: 'Guidelines'          },
  { id: 'getting-help',                                              label: 'Getting Help'        },
];
---
<Layout title="Contributing – SDE Team Development Hub" currentDomain="contributing">
  <div class="skills-framework">
    <div class="sticky-header">
      <h1>Contributing</h1>
    </div>
    <div class="sticky-subnav">
      <div class="subdomain-tabs" id="section-tabs">
        {sections.map(s => (
          <button class="tab subdomain-tab" data-section={s.id}>
            {s.label}
          </button>
        ))}
      </div>
    </div>
    <div class="scroll-area" id="scroll-area">
      <article class="prose prose--reset prose--lead">
        <Content />
      </article>
    </div>
  </div>
</Layout>

<script define:vars={{ sections }}>
  window._pageSections = sections;
</script>
<script>
  import { initScrollSync } from '../scripts/scrollSync.js';
  initScrollSync({ sections: window._pageSections });
  document.querySelector('#scroll-area h1')?.remove();
</script>
