---
import Sidebar from '../components/Sidebar.jsx';
import Footer from '../components/Footer.astro';
import { DOMAINS, PAGE_COLORS } from '../data/domains.js';
import 'bootstrap/dist/css/bootstrap.min.css';
import '../styles/theme.css';
import '../styles/base.css';
import '../styles/animations.css';
import '../styles/sidebar.css';
import '../styles/page-nav.css';
import '../styles/skills-framework.css';
import '../styles/prose.css';
import '../styles/page-container.css';
import '../styles/retreat.css';
import '../styles/acknowledgements.css';

interface Props {
  title: string;
  currentDomain?: string;
}

const { title, currentDomain = '/' } = Astro.props;
const domainColor = PAGE_COLORS[currentDomain] ?? 'var(--color-purple)';
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <!-- Inline: must run before first paint to prevent flash of unstyled theme -->
    <script is:inline>
      const saved = localStorage.getItem('theme') || 'light';
      document.documentElement.dataset.theme = saved;
      document.documentElement.dataset.bsTheme = saved;
    </script>
    <script define:vars={{ domainColor }} is:inline>
      document.documentElement.style.setProperty('--color-domain-base', domainColor);
    </script>
  </head>
  <body>
    <div class="app-wrapper">
      <Sidebar domains={DOMAINS} currentDomain={currentDomain} client:load />
      <main class="main-content">
        <slot />
      </main>
    </div>
    <script>
      import 'bootstrap/dist/js/bootstrap.bundle.min.js';
    </script>
  </body>
</html>
