---
import Layout from '../layouts/Layout.astro';
import '../styles/index.css';
import { featuredStudents } from '../data/students.js';
import { rtps } from '../data/rtps.js';
import { staff } from '../data/staff.js';

const siteLeads = staff.filter(s => s.siteLead);
const teamMembers = staff.filter(s => !s.siteLead);

const sections = [
  {
    id: 'our-project',
    label: 'Our Project',
    subsections: [
      { id: 'student-projects', label: 'Student Projects' },
      { id: 'rtp-placements', label: 'RTP Placements' },
      { id: 'team', label: 'Research Team' }
    ],
  },
   {
    id: 'competency-framework',
    label: 'Competency Framework',
    subsections: [
      { id: 'key-features', label: 'Key Features' },
    ],
  }
];
---

