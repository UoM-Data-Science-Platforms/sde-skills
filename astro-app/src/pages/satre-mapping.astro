---
import SatreMappingMatrix from '../components/SatreMappingMatrix.jsx';
import Layout from '../layouts/Layout.astro';
---
<Layout title="SATRE Mapping – SDE Team Development Hub" currentDomain="satre-mapping">
  <div class="skills-framework">
    <div class="sticky-header">
      <h1>SATRE Mapping</h1>
      <p class="page-description">
        How the SDE Skills Competency Framework subdomains address each component of the
        <a href="https://satre-specification.readthedocs.io/" target="_blank" rel="noopener" class="link--accent">Standard Architecture for Trusted Research Environments (SATRE)</a> specification.
      </p>
    </div>
    <div class="scroll-area">
      <SatreMappingMatrix client:load />
    </div>
  </div>
</Layout>
